# copy to the plugin config dir:  cp .env.example "$(herdr plugin config-dir tinysend.herdr)/.env"
# a mailbox-scoped key (sk_mbx_...) from tinysend.com — `from` defaults to its mailbox
TINYSEND_KEY=sk_mbx_...
# the mailbox's id (mbx_...)
TINYSEND_MAILBOX_ID=mbx_...
# where notifications land — your everyday inbox (you reply from here to drive the agent)
NOTIFY_TO=you@example.com
# which agent statuses trigger an email (comma-separated)
NOTIFY_ON=blocked,done,failed
# only email once you've been away this long (no input / screen locked), in minutes.
# avoids pinging you when you're sitting right there watching the pane. 0 = always.
# macOS only — on a remote Linux herdr host this is ignored (always notifies).
NOTIFY_AWAY_AFTER_MINUTES=30
# optional: a real one-line LLM summary instead of a scrollback tail
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
